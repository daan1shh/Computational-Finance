    "    ('Signal 2 - Donchian   |  Healthcare',  n_donchian_is,   n_donchian_oos),\n",
    "]:\n",
    "    full_metrics(n_is_,  spx_is,  f'{name}  --  IN-SAMPLE  (2010-2019)')\n",
    "    full_metrics(n_oos_, spx_oos, f'{name}  --  OUT-OF-SAMPLE  (2020-2025)')\n",
    "    print()"
