    "        rsi_grid_results.append(\n",
    "            ({'period': 14, 'oversold': os_, 'overbought': ob}, score))\n",
    "\n",
    "best_rsi = max(rsi_grid_results,\n",
    "               key=lambda x: x[1] if not np.isnan(x[1]) else -np.inf)\n",
    "_best_rsi_params, _best_rsi_score = best_rsi\n",
