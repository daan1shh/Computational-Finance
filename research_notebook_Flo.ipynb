    "\n",
    "pos_brk = np.concatenate(([0.0], sig_brk['signal'].to_numpy(dtype=float)[:-1]))\n",
    "pos_jpm = np.concatenate(([0.0], sig_jpm['signal'].to_numpy(dtype=float)[:-1]))\n",
